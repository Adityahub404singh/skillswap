{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://skillswap-b59w.onrender.com/api/$1"
    },
    {
      "source": "/sitemap:path*\\.xml",
      "destination": "/sitemap:path*.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/google876107b7140265e0.html",
      "destination": "/google876107b7140265e0.html"
    },
    {
      "source": "/((?!assets/|favicon\\.svg|logo\\.svg|opengraph\\.jpg|ads\\.txt).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.png",
      "headers": [
        { "key": "Content-Type", "value": "image/png" }
      ]
    }
  ]
}
