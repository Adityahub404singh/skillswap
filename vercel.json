{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://skillswap-b59w.onrender.com/api/$1"
    },
    {
      "source": "/(sitemap.*\\.xml|robots\\.txt|ads\\.txt|google876107b7140265e0\\.html)",
      "destination": "/$1"
    },
    {
      "source": "/((?!assets/|sitemap|robots\\.txt|favicon\\.svg|logo\\.svg|opengraph\\.jpg|ads\\.txt|google876107b7140265e0\\.html).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.png",
      "headers": [
        { "key": "Content-Type", "value": "image/png" }
      ]
    }
  ]
}
